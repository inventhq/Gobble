{
  "name": "@inventhq/tracker-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for tracker-core — generate signed/encrypted tracking URLs, batch-send events, and build click/postback/impression links. Zero dependencies.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node --import tsx --test src/**/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": ["tracker", "tracking", "sdk", "clicks", "postbacks", "impressions", "ad-tech", "analytics", "attribution", "click-tracking"],
  "license": "MIT",
  "author": "inventhq",
  "repository": {
    "type": "git",
    "url": "https://github.com/inventhq/tracker.git",
    "directory": "packages/sdk-typescript"
  },
  "homepage": "https://github.com/inventhq/tracker/tree/main/packages/sdk-typescript",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  }
}
