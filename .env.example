# URL validation mode: "signed" (HMAC) or "encrypted" (AES-256-GCM)
URL_MODE=signed

# Required when URL_MODE=signed
HMAC_SECRET=your-secret-key-here

# Required when URL_MODE=encrypted (must be exactly 32 bytes, hex-encoded)
# ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Iggy TCP server address
IGGY_URL=127.0.0.1:8090

# Iggy stream and topic names
IGGY_STREAM=tracker
IGGY_TOPIC=events

# Maximum events per POST /batch request
MAX_BATCH_SIZE=10000

# Server bind address
HOST=0.0.0.0
PORT=3030
